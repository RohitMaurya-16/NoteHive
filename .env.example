### Database (Supabase PostgreSQL - Required)
# Option A (Recommended): Use DATABASE_URL Session Pooler
DATABASE_URL=postgresql://postgres.[YOUR-PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres

# Option B: Individual fields
DB_HOST=db.[YOUR-PROJECT-REF].supabase.co
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=[YOUR-PASSWORD]
DB_NAME=postgres
DB_SSL=true

### Frontend API URL (update for production)
VITE_API_URL=http://localhost:4000

### AI Chatbot (Required for embeddings/RAG)
OPENAI_API_KEY=sk-...
OPENAI_EMBED_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_API_BASE=https://api.openai.com/v1

# Alternative providers (fallback if OpenAI missing)
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# Local Ollama (http://host.docker.internal:11434 from Render)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=llama3.2:3b

### Chat Settings
CHAT_TOP_K=6
CHAT_INTERNAL_MIN_SIMILARITY=0.72
CHAT_MAX_HISTORY=12
CHAT_MAX_NOTE_CHUNKS=16
CHAT_NOTE_CHUNK_SIZE=900

### Admin (Optional)
CHAT_REINDEX_KEY=your-secret-key

### Server
PORT=4000

